// generator と datasource は prisma init が作ったものをそのまま使う
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ここから下を追加する
model User {
  id   Int    @id @default(autoincrement())
  name String
  age  Int?   // 「?」を付けることで、年齢が分からない人がいてもOKにするぞ
}

